{
  "name": "@em-ui/react-ui",
  "version": "0.1.0",
  "description": "A React UI component library",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/components/index.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "files": ["dist"],
  "sideEffects": ["**/*.css", "dist/styles.css"],
  "scripts": {
    "build:lib": "vite build --config vite.lib.config.ts",
    "type-check": "tsc --project tsconfig.lib.json --noEmit",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:coverage": "vitest run --project=unit --coverage",
    "test:browser": "vitest run --project=storybook",
    "test:all": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "lucide-react": "^0.475.0"
  },
  "devDependencies": {
    "@em-ui/tokens": "workspace:*",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.3",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.3",
    "@storybook/nextjs-vite": "^10.4.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint-plugin-storybook": "^10.4.3",
    "jsdom": "^27.0.1",
    "playwright": "^1.52.0",
    "prettier": "^3.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.4.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  }
}
